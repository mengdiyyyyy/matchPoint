rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles inside a shared pool.
    // Identity is a name+PIN-derived account id (not the anonymous auth uid),
    // so the doc id no longer equals request.auth.uid. Any signed-in user may
    // create/update a profile doc. This is the accepted trade-off of the
    // lightweight name+PIN scheme (class-internal use). Tighten before any
    // real production use.
    match /pools/{poolId}/users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Agent-to-agent chat transcripts.
    // For the school-demo scope we keep this auth-only on both read and write —
    // any signed-in user in this Firebase project can read/write. The chat doc
    // schema doesn't carry the writer's own uid, so per-document ownership
    // checks would need a schema change. Tighten before any real production use.
    match /pools/{poolId}/chats/{chatId} {
      allow read, write: if request.auth != null;
    }

    // Lock everything else down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
